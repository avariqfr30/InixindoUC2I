APP_PROFILE=production
APP_MODE=hybrid
HOST=127.0.0.1
PORT=8000
WAITRESS_THREADS=6
WAITRESS_CONNECTION_LIMIT=100
WAITRESS_CHANNEL_TIMEOUT=240
REPORT_JOB_WORKERS=2
REPORT_MAX_PENDING_JOBS=16
REPORT_JOB_RETENTION_SECONDS=86400
OSINT_CACHE_TTL_SECONDS=21600
ENABLE_VECTOR_INDEX=0
SESSION_COOKIE_SECURE=1
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_ACTIVITY_TOUCH_SECONDS=60
SESSION_MAX_ACTIVE_PER_USER=1
SESSION_MAX_ACTIVE_TOTAL=24
ALLOW_SIGNUP=0
APP_SECRET_KEY=change-this-production-secret
SERPER_API_KEY=YOUR_SERPER_API_KEY
INTERNAL_CONNECTOR_PATH="${APP_ROOT}/internal_connector.production.json"
INTERNAL_API_AUTH_MODE=basic
INTERNAL_API_USERNAME=change_me
INTERNAL_API_PASSWORD=change_me
INTERNAL_API_TIMEOUT_SECONDS=20
